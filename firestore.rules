rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.get('email_verified', false) == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        (isEmailVerified() && exists(/databases/$(database)/documents/admins/$(request.auth.uid))) ||
        (request.auth.token.get('email', '').lower() == 'homoloy422@gmail.com') ||
        (request.auth.token.get('email', '').lower() == 'turunghomoloy98@gmail.com') ||
        (request.auth.token.get('email', '').lower() == 'ayushman15899@gmail.com')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ---------------------------------------------------------
    // VALIDATION BLUEPRINTS
    // ---------------------------------------------------------

    function isValidMember(data) {
      return data.keys().hasAll(['fullName', 'phone', 'whatsapp', 'joinDate', 'planId', 'feesAmount', 'dueDate', 'gender', 'status'])
        && data.fullName is string && data.fullName.size() >= 2 && data.fullName.size() <= 100
        && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20
        && data.whatsapp is string && data.whatsapp.size() >= 8 && data.whatsapp.size() <= 20
        && data.joinDate is string && data.joinDate.size() <= 64
        && data.planId is string && data.planId.size() <= 64
        && data.feesAmount is number && data.feesAmount >= 0
        && data.dueDate is string && data.dueDate.size() <= 64
        && data.gender in ['male', 'female', 'other']
        && data.status in ['active', 'inactive']
        && (data.get('notes', '') is string && data.get('notes', '').size() <= 1000)
        && (data.get('photoUrl', '') is string && data.get('photoUrl', '').size() <= 1000);
    }

    function isValidPlan(data) {
      return data.keys().hasAll(['name', 'amount', 'durationMonths'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.amount is number && data.amount >= 0
        && data.durationMonths is number && data.durationMonths > 0 && data.durationMonths <= 120;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['memberId', 'amount', 'date', 'method', 'type'])
        && data.memberId is string && data.memberId.size() <= 64
        && data.amount is number && data.amount > 0
        && data.date is string && data.date.size() <= 64
        && data.method is string && data.method.size() <= 50
        && data.type is string && data.type.size() <= 50;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['memberId', 'date', 'checkInTime'])
        && data.memberId is string && data.memberId.size() <= 64
        && data.date is string && data.date.size() <= 20
        && data.checkInTime is string && data.checkInTime.size() <= 64;
    }

    // ---------------------------------------------------------
    // DEFAULT DENY
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // RULES
    // ---------------------------------------------------------

    match /members/{memberId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(memberId) && isValidMember(incoming());
      allow update: if isAdmin() && isValidMember(incoming());
      allow delete: if isAdmin();
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(planId) && isValidPlan(incoming());
      allow update: if isAdmin() && isValidPlan(incoming());
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(paymentId) && isValidPayment(incoming());
      allow update: if isAdmin() && isValidPayment(incoming());
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidId(attendanceId) && isValidAttendance(incoming());
      allow update: if isAdmin() && isValidAttendance(incoming());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }
  }
}
